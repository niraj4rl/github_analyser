# Copy this file to .env and paste your GitHub personal access token below.
# Create the token in GitHub: Settings > Developer settings > Personal access tokens.
GITHUB_TOKEN=
GITHUB_API_BASE=https://api.github.com
APP_TITLE=Intelligent Developer Hiring & Analytics System
MAX_REPOS=6
MAX_COMMITS_PER_REPO=60
ANALYSIS_WEEKS=52
REQUEST_TIMEOUT_SECONDS=20

# PostgreSQL connection settings for GitInsight
DB_NAME=gitinsight
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# Optional legacy aliases (supported for backward compatibility)
# PGDATABASE=gitinsight
# PGUSER=your_postgres_user
# PGPASSWORD=your_postgres_password
# PGHOST=localhost
# PGPORT=5432

